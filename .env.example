# =======================================================
# EssayGrader Pro — Environment Variables
# =======================================================
#
# Frontend (.env.local in the project root):
# -------------------------------------------------------
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# =======================================================
# Convex environment variables (set with `npx convex env set`):
# -------------------------------------------------------
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# S3_BUCKET=essaygrader-uploads-<your-unique-suffix>
# BEDROCK_MODEL_ID=amazon.nova-pro-v1:0      # or amazon.nova-lite-v1:0 for faster / cheaper
#
# Set these by running:
#   npx convex env set AWS_ACCESS_KEY_ID "AKIA..."
#   npx convex env set AWS_SECRET_ACCESS_KEY "..."
#   npx convex env set AWS_REGION "us-east-1"
#   npx convex env set S3_BUCKET "essaygrader-uploads-yourname"
#   npx convex env set BEDROCK_MODEL_ID "amazon.nova-pro-v1:0"
# =======================================================
